# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py

# Secret Key (Generate a secure one for production)
SECRET_KEY=your-secret-key-change-this-in-production

# Application Settings
DEBUG=False
TESTING=False

# Model Configuration
MODEL_PATH=diabetes-prediction-rfc-model.pkl

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# CORS Configuration
CORS_ORIGINS=*

# Database (if needed in future)
DATABASE_URL=sqlite:///app.db

# Deployment
WORKERS=4
THREADS=2
